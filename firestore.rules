rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if requester is admin
    function isAdmin() {
      return request.auth != null &&
        request.auth.token.email in [
          'macarena@dtcomunicacion.com',
          'emilianobenavente@dtcomunicacion.com'  // reemplazar con email de Emi
        ];
    }

    // Users: each user can read/write their own doc; all authenticated can read others
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Matches: anyone can read; only admins can write
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Predictions: authenticated users can read all, but only write their own
    match /predictions/{predId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null &&
        request.auth.uid == resource.data.userId ||
        (request.auth != null && !exists(/databases/$(database)/documents/predictions/$(predId)));
      // More permissive write rule for new docs:
      allow create: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid;
    }
  }
}
